{
  "buildCommand": "cd artifacts/portfolio && pnpm build",
  "outputDirectory": "artifacts/portfolio/dist",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "PORT": "5173"
  }
}
